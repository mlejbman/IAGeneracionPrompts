            "Avanzado                      3850.0                2.5   \n",
            "Básico                        1150.0                0.0   \n",
            "Intermedio                    1800.0                1.0   \n",
            "\n",
            "              Horas de Estudio/Lectura  \n",
            "Nivel_Ingles                            \n",
            "Avanzado                           4.5  \n",
            "Básico                            13.5  \n",
            "Intermedio                         8.0  \n",
            "\n",
            "📈 ¡Quienes dominan el inglés ganan un 234.8% más que quienes tienen nivel básico!\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Importante: Ejecutar el código anterior, para que funcione éste.\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Uso el DataFrame 'metricas', obtenido en el código anterior, para poder visualizar los datos, importando la librería matplotlib.\n",
        "\n",
        "plt.figure(figsize=(10, 6))\n",
        "\n",
        "# Defino los colores: un gris apagado para el nivel básico y un azul vibrante para el avanzado\n",
        "colores = ['#FF4B4B', '#36454F', '#1E90FF'] # Rojo (Básico), Gris (Intermedio), Azul (Avanzado)\n",
        "\n",
        "# Crear gráfico de barras\n",
        "barras = plt.bar(metricas.index, metricas['Salario Promedio (USD)'], color=colores)\n",
        "\n",
        "# Configuración estética\n",
        "plt.title('El \"Muro\" Salarial: Impacto del Inglés en tus Ingresos', fontsize=16, pad=20)\n",
        "plt.ylabel('Salario Mensual (USD)', fontsize=12)\n",
        "plt.xlabel('Nivel de Inglés', fontsize=12)\n",
        "plt.grid(axis='y', linestyle='--', alpha=0.7)\n",
        "\n",
        "# Añadir etiquetas de datos sobre las barras\n",
        "for barra in barras:\n",
        "    yval = barra.get_height()\n",
        "    plt.text(barra.get_x() + barra.get_width()/2, yval + 100, f'${yval:,.0f}',\n",
        "             ha='center', va='bottom', fontweight='bold', fontsize=12)\n",
        "\n",
        "# Mostrar el gráfico\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
